# ============================================================
# Iris Chat Widget — Environment Variables
# Kopiraj u .env i popuni sve obavezne varijable prije deploy
# ============================================================

# --- Anthropic ---
# OBAVEZNO: API ključ za Claude Haiku
ANTHROPIC_API_KEY=sk-ant-...

# --- Klijent identifikacija ---
# OBAVEZNO: Jedinstveni ID klijenta (slug, bez razmaka, bez velikih slova)
# Koristi se za subdomain: CLIENT_ID.chat.digitalnature.at
CLIENT_ID=mato-fotografija

# OBAVEZNO: Kratko ime klijenta (Iris ga koristi u razgovoru)
CLIENT_NAME=Mato

# OBAVEZNO: Puno ime firme/brenda
BUSINESS_NAME=Mato Fotografija

# Radno vrijeme (opcionalno — ako se postavi, Iris informira van radnog vremena)
# Format: "Mo-Fr 08:00-18:00"
BUSINESS_HOURS=Mo-Fr 08:00-18:00

# --- Iris ponašanje ---
# Opcionalno: Custom system prompt. Ako se izostavi, koristi se defaultni template.
# IRIS_SYSTEM_PROMPT=Ti si Mato, ljubazni asistent Mato Fotografija...

# --- Server ---
# Port na kojem sluša Express server (ne mijenjaj bez promjene Traefik labela)
WIDGET_PORT=3002

# --- Telegram notifikacije za leadove (opcionalno) ---
# Bot token dobijen od @BotFather
# TELEGRAM_BOT_TOKEN=123456789:AAF...

# Admin Telegram chat ID za primanje notifikacija o leadovima
# ADMIN_TELEGRAM_ID=123456789
