CLIENT_NAME=Iris               # bot display name
BUSINESS_NAME=                 # company name, e.g. "GK Autoteile"
BUSINESS_HOURS=Mo-Fr 08:00-18:00  # optional — outside hours bot adds a note
OWNER_TELEGRAM_ID=             # your Telegram user ID — receives lead notifications
# IRIS_SYSTEM_PROMPT=          # optional: fully custom system prompt override
